# Порт, который слушает приложение внутри контейнера / процесса.
PORT=8080

# Код редиректа по умолчанию для всех route, если route не переопределяет его явно.
# Допустимые значения: 301, 302, 307, 308.
# По умолчанию 307.
REDIRECT_STATUS_CODE=307

# Глобальный default для Link: rel="canonical".
# Любая конкретная route может переопределить это значение.
ENABLE_CANONICAL_HEADER=false

# Таблица соответствий "source=>destination|option=value".
# Разделители записей: запятая, точка с запятой или перевод строки.
# Примеры:
# ROUTES=promo=>/promo,docs=>/documentation
# ROUTES=promo.example.com=>https://landing.example.org/promo|status=302|canonical=true
# ROUTES=docs.eu.example.com=>https://docs.example.org/eu;help=>/support|status=307
#
# Важно:
# - source может быть либо первым label, либо полным host;
# - destination может быть либо путем, либо полным URL;
# - status и canonical в route опциональны и перебивают глобальные defaults;
# - если destination это путь, приложение само берет схему и parent host из входящего запроса.
ROUTES=promo=>/promo,docs=>/documentation,help=>/support
